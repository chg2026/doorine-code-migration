# rei-code monorepo — consolidated secrets checklist
# ----------------------------------------------------
# This is a TOP-LEVEL CHECKLIST of every secret the two products need.
# Each app keeps its own focused .env.example; copy from the per-app file
# when running that app locally. In production, secrets are partitioned by
# deployment (Gold Bridge deployment vs CHG Rehab deployment) — never share.
#
#   Per-app env templates:
#   - apps/crm/.env.example         (Gold Bridge: CHG CRM front-end)
#   - apps/deallink/.env.example    (Gold Bridge: Deal Link front-end, if present)
#   - apps/chg-rehab/.env.example   (CHG Rehab: Next.js app — full list w/ comments)
#
#   In Replit dev, all of these live in the workspace Secrets pane and are
#   visible to every workflow. In production they are partitioned by
#   deployment (each deployment has its own secrets pane).

# ── Gold Bridge (server + apps/crm + apps/deallink) ───────────────────────
# Used by server/ and apps/crm/. See apps/crm/.env.example for details.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NODE_ENV=
PORT=

# ── CHG Rehab (apps/chg-rehab) ────────────────────────────────────────────
# Auto-provided by Replit (Postgres module + OIDC + dev domain).
DATABASE_URL=
PGHOST=
PGPORT=
PGUSER=
PGPASSWORD=
PGDATABASE=
REPL_ID=
REPLIT_DOMAINS=
REPLIT_DEV_DOMAIN=

# Iron-session cookie auth (32+ char random string).
SESSION_SECRET=

# Replit OIDC overrides (defaults are correct).
ISSUER_URL=
APP_BASE_URL=
NEXT_PUBLIC_APP_URL=
DEV_LOGIN_ENABLED=

# Stripe (live + test, plus webhook signing secret).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_TEAM=

# Resend (transactional email).
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=

# Google Cloud Storage (uploads via signed URLs).
GCS_BUCKET=
GCS_PROJECT_ID=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=

# Cron / notifications scheduler tuning.
NOTIFICATIONS_SCHEDULER_INTERVAL_MS=
NOTIFICATIONS_SCHEDULER_INITIAL_DELAY_MS=
NOTIFICATIONS_SCHEDULER_DISABLED=

# See apps/chg-rehab/.env.example for inline notes on each variable.
