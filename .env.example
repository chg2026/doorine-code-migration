# rei-code monorepo — consolidated secrets checklist
# ----------------------------------------------------
# This is the TOP-LEVEL CHECKLIST of every secret the two products need.
# The authoritative per-app templates (with inline notes on each variable)
# live alongside the apps:
#
#   - apps/chg-rehab/.env.example   CHG Rehab: Next.js app (full descriptions)
#   - apps/deallink/.env.example    Deal Link: Vite front-end Supabase keys
#
# (The legacy apps/crm CRA front-end was retired in CHG Phase 5 and lives
# under archive/apps-crm/ — its env template is no longer authoritative.)
#
# (Deal Link does not yet ship its own .env.example — it currently uses
# only the Gold Bridge Supabase variables listed below.)
#
# In Replit dev, all of these live in the workspace Secrets pane and are
# visible to every workflow. In production they are partitioned by
# deployment (each deployment has its own secrets pane and they should NOT
# share secrets). Names below match the variables actually referenced by
# `process.env.NAME` in the source — keep this file in sync with the
# per-app templates.

# ── Gold Bridge (server + apps/deallink) ─────────────────────────────────
# Used by server/ and apps/deallink/. The shared Express server still
# powers chg-rehab's /api/admin/* and Deal Link's /api/deallink/*.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NODE_ENV=
PORT=

# ── CHG Rehab (apps/chg-rehab) ────────────────────────────────────────────
# Mirror of apps/chg-rehab/.env.example. See that file for inline notes.

# Database (Prisma → PostgreSQL). Auto-provided by Replit's postgresql-16 module.
DATABASE_URL=

# Iron-session cookie auth (32+ char random string).
SESSION_SECRET=

# Replit OIDC (auto-provided by Replit at runtime).
REPL_ID=
REPLIT_DOMAINS=
REPLIT_DEV_DOMAIN=
ISSUER_URL=
APP_BASE_URL=
NEXT_PUBLIC_APP_URL=
DEV_LOGIN_ENABLED=

# Stripe (billing) — names match lib/stripe.ts exactly.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_OPERATOR=
STRIPE_PRICE_ENTERPRISE=

# Email (Resend HTTP API) — names match lib/outboundEmail.ts exactly.
RESEND_API_KEY=
EMAIL_FROM=

# Replit Object Storage (file uploads, GCS-backed under the hood).
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=
OBJECT_STORAGE_HEALTH_TIMEOUT_MS=
REPLIT_CONNECTORS_HOSTNAME=

# Notification scheduler (in-process + external cron).
# CRON_SECRET is required — /api/cron/notifications-sweep refuses to run without it.
CRON_SECRET=
NOTIFICATIONS_SWEEP_INTERVAL_MS=
NOTIFICATIONS_SWEEP_DISABLED=

# Smoke / test helpers (optional).
SMOKE_ADMIN_ID=
SMOKE_ORIGIN=
